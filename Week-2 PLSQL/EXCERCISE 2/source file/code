-- SCENARIO 3

CREATE OR REPLACE PROCEDURE AddNewCustomer(
    p_id NUMBER,
    p_name VARCHAR2,
    p_dob DATE,
    p_balance NUMBER
)
IS
BEGIN
    INSERT INTO Customers
    VALUES(p_id,p_name,p_dob,p_balance,SYSDATE);

    COMMIT;

EXCEPTION
    WHEN DUP_VAL_ON_INDEX THEN
        DBMS_OUTPUT.PUT_LINE('Customer ID Already Exists');
END;
/

BEGIN
    AddNewCustomer(
        3,
        'Robert King',
        DATE '1988-01-10',
        12000
    );
END;
/

